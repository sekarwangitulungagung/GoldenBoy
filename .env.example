# Environment Settings for Sekar Wangi Tally Pro Control

# OBS WebSocket Settings
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=

# vMix API Settings (used when SWITCHER_TYPE=vmix)
VMIX_HOST=localhost
VMIX_PORT=8088

# Switcher Selection: obs | vmix
SWITCHER_TYPE=obs

# MIDI Settings
MIDI_PORT_NAME=Arduino MIDI

# Application Settings
APP_VERSION=01
APP_NAME=GOLDENBOY
APP_AUTHOR=Sekar Wangi Multimedia
APP_DESCRIPTION=Control your OBS Studio with MIDI devices using Sekar Wangi Tally Pro Control.
APP_MODE=development
CHANNEL_COUNT=8

# Logging
LOG_LEVEL=INFO
LOG_FILE=tally_log.txt