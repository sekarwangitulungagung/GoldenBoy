#!/bin/bash
# Sekar Wangi Tally Pro Control - macOS Launcher

# Get the directory where this script is located
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Change to the Resources directory where the Python files are
cd "$DIR/../Resources"

# Check if Python 3 is available
if ! command -v python3 &> /dev/null; then
    echo "Python 3 is not installed. Please install Python 3.9 or higher from https://www.python.org"
    echo "Or install via Homebrew: brew install python3"
    exit 1
fi

# Check Python version
PYTHON_VERSION=$(python3 -c 'import sys; print(".".join(map(str, sys.version_info[:2])))')
REQUIRED_VERSION="3.9"

if [ "$(printf '%s\n' "$REQUIRED_VERSION" "$PYTHON_VERSION" | sort -V | head -n1)" != "$REQUIRED_VERSION" ]; then
    echo "Python $PYTHON_VERSION found, but Python $REQUIRED_VERSION or higher is required."
    exit 1
fi

# Install dependencies if needed
if [ ! -d "$HOME/Library/Python/$PYTHON_VERSION/site-packages/obsws_python" ]; then
    echo "Installing Python dependencies..."
    python3 -m pip install --user -r requirements.txt
fi

# Run the application
python3 main.py